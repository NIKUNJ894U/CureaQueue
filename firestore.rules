rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Direct catches
    match /patients/{patientId} {
      allow read, write: if true;
    }
    match /queueConfig/{configId} {
      allow read, write: if true;
    }
    
    // Global fallback rule - deny anything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
